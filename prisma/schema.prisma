generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id             String   @id @default(cuid())
  name           String
  phone          String
  location       String?
  message        String?
  source         String?
  status         String   @default("new")
  nextFollowUpAt DateTime?
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("Lead")
}