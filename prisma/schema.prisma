generator client {
	provider = "prisma-client-js"
}

datasource db {
	provider = "postgresql"
}

model Lead {
	id        String   @id @default(uuid())
	name      String
	email     String?
	phone     String?
	address   String?
	service   String?
	notes     String?
	message   String?
	source    String?
	location  String?
	status    String?
	nextFollowUpAt DateTime?
	createdAt DateTime @default(now())
	updatedAt DateTime @updatedAt
}
